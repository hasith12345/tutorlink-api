# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tutorlink"
DIRECT_URL="postgresql://user:password@localhost:5432/tutorlink"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES=7d

# Auth0 OAuth
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_CALLBACK_URL=http://localhost:5000/api/auth/oauth/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=TutorLink <onboarding@resend.dev>
CONTACT_RECIPIENT=your-email@gmail.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
