# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tutorlink"

# JWT Secret
JWT_SECRET="your-jwt-secret-key-here"

# Email Configuration
# For Gmail (Recommended for production)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password  # Use App Password from Google Account settings
EMAIL_FROM="TutorLink <noreply@tutorlink.com>"

# Alternative: SMTP Configuration (for other email services)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="TutorLink <noreply@tutorlink.com>"

# Environment
NODE_ENV=development
