// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User table: Authentication only
// - A user logs in ONCE using email + password
// - Roles are NOT stored here
// - Roles are determined by the existence of Student/Tutor profiles
model User {
  id                     String    @id @default(uuid()) @db.Uuid
  fullName               String
  email                  String    @unique  // Email must be unique - one account per email
  password               String
  isEmailVerified        Boolean   @default(false)
  emailVerificationCode  String?
  verificationCodeExpiry DateTime?
  passwordResetToken     String?
  passwordResetExpiry    DateTime?
  isOAuthUser            Boolean   @default(false)
  isBanned               Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  student                Student?  // Optional - if exists, user has student role
  tutor                  Tutor?    // Optional - if exists, user has tutor role
}

// Student profile table
// - Created when user signs up as Student OR adds Student role later
// - userId is UNIQUE - a user can have only ONE student profile
model Student {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid  // One-to-one with User
  dob            String?
  phone          String?
  address        String?
  schoolGrade    String?
  schoolName     String?
  parentName     String?
  parentPhone    String?
  avatar         String?      // Profile image URL (Cloudinary)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
}

// Tutor profile table
// - Created when user signs up as Tutor OR adds Tutor role later
// - userId is UNIQUE - a user can have only ONE tutor profile
model Tutor {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid  // One-to-one with User
  dob             String?
  phone           String?
  address         String?
  location        String?  // City/Region for search
  idNumber        String?
  
  // Professional Information
  subject         String?  // Main subject (e.g., Mathematics, Physics)
  subjects        String[] // Multiple subjects the tutor teaches
  bio             String?  // Short bio/description
  experience      String?  // Years of experience (e.g., "5 years")
  education       String?  // Educational background
  hourlyRate      Int?     // Price per hour in cents (e.g., 5000 = $50.00)
  
  // Teaching Preferences
  learningMode    String?  // "online", "physical", "hybrid"
  
  // Stats & Ratings
  rating          Float    @default(0.0)  // Average rating
  totalReviews    Int      @default(0)    // Number of reviews
  totalStudents   Int      @default(0)    // Total students taught
  
  // ID Verification Documents
  idCopyFront     String?  // Front side of ID/NIC image URL (Cloudinary)
  idCopyBack      String?  // Back side of ID/NIC image URL (Cloudinary)
  idCopyPdf       String?  // ID copy as PDF URL (Cloudinary) - alternative to images

  // Tutor Application / Onboarding
  cvUrl           String?  // CV file URL (Cloudinary)
  qualifications  String?  // Qualifications summary
  applicationStatus String @default("NOT_SUBMITTED") // NOT_SUBMITTED | PENDING | APPROVED | REJECTED

  // Profile Status
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  avatar          String?  // Avatar URL
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes         Class[]  // Classes created by this tutor
}

// Class table - Tutor-created classes/sessions
model Class {
  id              String   @id @default(uuid()) @db.Uuid
  tutorId         String   @db.Uuid
  subject         String
  description     String?
  venue           String?
  mode            String   // "online" | "physical"
  location        String?
  date            DateTime
  schedule        String[] // e.g. ["MON","WED","FRI"] — recurring days
  time            String   // e.g. "4:00 PM"
  duration        String   // e.g. "2 hours"
  fees            Int      // in LKR (e.g., 2500)
  maxStudents     Int      @default(10)
  enrolledCount   Int      @default(0)
  meetingLink     String?  // Zoom / Meet / Teams URL
  status          String       @default("ACTIVE") // ACTIVE | CANCELLED | COMPLETED
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tutor           Tutor        @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  enrollments     Enrollment[]
  folders         ClassFolder[]
}

model ClassFolder {
  id        String          @id @default(uuid()) @db.Uuid
  classId   String          @db.Uuid
  name      String
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  materials ClassMaterial[]
}

model ClassMaterial {
  id           String      @id @default(uuid()) @db.Uuid
  folderId     String      @db.Uuid
  name         String
  description  String?
  url          String
  publicId     String
  resourceType String      // "image" | "document" | "video"
  mimeType     String
  sizeBytes    Int?
  isPublished  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  folder       ClassFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String    @id @default(uuid()) @db.Uuid
  studentId   String    @db.Uuid
  classId     String    @db.Uuid
  status      String    @default("ACTIVE")   // ACTIVE | CANCELLED
  enrolledAt  DateTime  @default(now())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  payment     Payment?

  @@unique([studentId, classId])
}

model Payment {
  id               String      @id @default(uuid()) @db.Uuid
  enrollmentId     String      @unique @db.Uuid
  stripePaymentId  String      @unique
  totalAmount      Int         // full class fees in LKR
  tutorAmount      Int         // 92% of totalAmount
  platformAmount   Int         // 8% of totalAmount
  currency         String      @default("lkr")
  status           String      @default("PENDING")  // PENDING | COMPLETED | FAILED
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  enrollment       Enrollment  @relation(fields: [enrollmentId], references: [id])
}
